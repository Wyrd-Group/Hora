{
  "name": "hora",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "cap:sync": "npm run build && cap sync",
    "cap:copy": "cap copy",
    "cap:update": "cap update",
    "cap:doctor": "cap doctor",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "ios:open": "cap open ios",
    "ios:run": "npm run build && cap sync ios && cap run ios",
    "ios:build": "npm run build && cap sync ios && cap open ios",
    "android:open": "cap open android",
    "android:run": "npm run build && cap sync android && cap run android",
    "android:build": "npm run build && cap sync android && cap open android",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "desktop:mac": "tauri build --target universal-apple-darwin",
    "desktop:win": "tauri build --target x86_64-pc-windows-msvc",
    "desktop:linux": "tauri build --target x86_64-unknown-linux-gnu"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@deck.gl/aggregation-layers": "^9.3.6",
    "@deck.gl/core": "^9.3.6",
    "@deck.gl/geo-layers": "^9.3.6",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mesh-layers": "^9.2.11",
    "@deck.gl/react": "^9.3.6",
    "@sentry/react": "^10.48.0",
    "@stripe/stripe-js": "^9.9.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-os": "^2.0.0",
    "@tauri-apps/plugin-window-state": "^2.0.0",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/distance": "^7.3.5",
    "bad-words": "^4.0.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "dompurify": "^3.4.11",
    "fuzzysort": "^3.1.0",
    "h3-js": "^4.5.0",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.38.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-map-gl": "^8.1.1",
    "recharts": "^3.9.2",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.5.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13",
    "fast-xml-parser": "^5.7.0",
    "protocol-buffers-schema": "^3.6.1",
    "dompurify": "^3.4.11"
  }
}
