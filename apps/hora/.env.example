# ── Client-side (Vite — exposed to browser) ──────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_BASE=http://localhost:8000

# ── Feature flags ────────────────────────────────────────────
# Substrate Mode is R&D (Phase 2+). Off in production by default.
# Flip to "true" to expose globally, OR grant per-user access via
# Supabase user_metadata.substrate_tester = true.
VITE_SUBSTRATE_PUBLIC=false

# ── Athena AI Providers (Netlify Functions + Vite dev server) ─
# At least one provider is required for Athena to function.
# Priority: Ollama (free local) → Gemma (self-hosted) → Blackbox → Gemini → Anthropic (paid)
ANTHROPIC_API_KEY=sk-ant-...
BLACKBOX_API_KEY=
BLACKBOX_API_MODEL=blackboxai
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMMA_CLOUD_URL=
GEMMA_CLOUD_MODEL=gemma4:26b-a4b
GEMMA_CLOUD_KEY=

# ── Local AI (Ollama — free, runs on your machine) ───────────
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── OpenAI-compatible provider ────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# ── Supabase Server-side (Netlify Functions only) ─────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe (Payments) ────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Sentry (Error Tracking) ──────────────────────────────────
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Scheduled Functions ──────────────────────────────────────
NETLIFY_CRON_SECRET=
