{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hora",
  "version": "1.0.0",
  "identifier": "com.quadratic.hora",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:9999",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hora",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#060a12",
        "dragDropEnabled": false,
        "windowEffects": {
          "effects": [
            "hudWindow"
          ],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost https: wss:; frame-src 'self' https:; worker-src 'self' blob:;"
    },
    "macOSPrivateApi": true,
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Build your financial empire.",
    "longDescription": "Hora \u2014 tap, build, raid, repeat. A finance-themed mobile strategy game.",
    "copyright": "Copyright (c) 2026 Quadratic. All rights reserved.",
    "publisher": "Quadratic",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": [
          "English"
        ],
        "installerIcon": "icons/icon.ico"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  }
}