# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mss:mssdev@localhost:5432/mss
POSTGRES_PASSWORD=mssdev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Ollama (local LLM — runs in Docker, no API key required) ─────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3:8b

# ── External data sources (leave blank for AIR_GAP_MODE=true) ────────────────
# OpenSky Network credentials (optional — increases rate limit)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# AISStream.io API key for live AIS maritime data
AISSTREAM_API_KEY=

# GDELT document API endpoint (default is public free tier)
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc

# ACLED armed conflict data (free key at https://acleddata.com/register/)
ACLED_API_KEY=
ACLED_EMAIL=

# ── Operations ────────────────────────────────────────────────────────────────
# Set true to disable ALL external API calls (uses seed data only)
AIR_GAP_MODE=false

# ── App ───────────────────────────────────────────────────────────────────────
APP_VERSION=0.1.0
LOG_LEVEL=info
