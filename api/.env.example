# Quadratic API Server Configuration
# Copy to .env and customize for your environment

# Server Configuration
PORT=8888
LOG_LEVEL=INFO

# Engine Configuration (optional, can override defaults)
PORTFOLIO_ENGINE_TIMEOUT=30
FORECAST_ENGINE_TIMEOUT=60
ANOMALY_SCAN_LIMIT=1000

# Data Feed Configuration
MARKET_DATA_SOURCE=local
AIS_DATA_SOURCE=local
ML_BENCHMARKS_SOURCE=local

# Sentinel Configuration
SENTINEL_THREAT_THRESHOLD=0.7
SENTINEL_ANOMALY_THRESHOLD=0.6
SENTINEL_CHECK_INTERVAL_SEC=60
SENTINEL_ENABLED=true

# API Authentication (optional — server is open if unset)
# QUADRATIC_API_KEY=your-secret-api-key

# Live Data Feed API Keys
# ODDS_API_KEY=your-odds-api-key       # https://the-odds-api.com (free tier 500 req/mo)
# NEWSAPI_KEY=your-newsapi-key         # https://newsapi.org
# FRED_API_KEY=your-fred-api-key       # https://fred.stlouisfed.org/docs/api/api_key.html
# POLYGON_API_KEY=your-polygon-key     # https://polygon.io

# Optional: External Services
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# Optional: Monitoring
# SENTRY_DSN=https://your-sentry-dsn
# DATADOG_API_KEY=your-datadog-key
